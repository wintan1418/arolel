<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : (page_title || app_name) %></title>
    <% if meta_description %><meta name="description" content="<%= meta_description %>"><% end %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= app_name %>">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#f6f5f1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= favicon_link_tag "logo/favicon-32.png", type: "image/png" %>
    <link rel="icon" type="image/png" sizes="16x16" href="<%= asset_path("logo/favicon-16.png") %>">
    <link rel="icon" type="image/png" sizes="48x48" href="<%= asset_path("logo/favicon-48.png") %>">
    <link rel="icon" type="image/svg+xml" href="<%= asset_path("logo/arolel-bundle.svg") %>">
    <link rel="apple-touch-icon" href="<%= asset_path("logo/arolel-app-icon-1024.png") %>">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body data-controller="receipt">
    <%= render "shared/header" %>

    <main class="tb-shell tb-page">
      <% if flash[:alert] %>
        <div class="tb-card tb-card-pad" style="margin-bottom: 20px; border-color: var(--tb-red); color: var(--tb-red-deep);">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <% if flash[:notice] %>
        <div class="tb-card tb-card-pad" style="margin-bottom: 20px; border-color: var(--tb-green);">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
