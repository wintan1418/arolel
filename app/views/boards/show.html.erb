<section data-controller="down" data-down-slug-value="<%= @board.slug %>" data-down-interval-value="60000">
  <div class="tb-tool-head">
    <div class="tb-tool-copy">
      <div class="tb-eyebrow">Tool 03 · Board</div>
      <h1 class="tb-h1 tb-tool-title" style="margin-top: 10px;"><%= @board.name %></h1>
      <div class="tb-mono tb-muted" style="margin-top: 8px; font-size: 13px;">
        <%= @board.hosts.size %> hosts · last checked <span data-down-target="lastCheckedRel">
          <%= @board.last_checked_at ? time_ago_in_words(@board.last_checked_at) + " ago" : "pending" %>
        </span>
      </div>
    </div>
    <div class="tb-actions-inline">
      <button class="tb-btn tb-btn-ghost" data-action="click->down#copyShare">
        Copy share link
      </button>
      <button class="tb-btn tb-btn-primary" data-action="click->down#refresh" data-down-target="refreshBtn">
        Check now
      </button>
    </div>
  </div>

  <div class="tb-tool-layout tb-tool-layout-narrow" style="margin-top: 28px;">
    <div class="tb-card" data-down-target="tableWrap">
      <%= render "boards/table", board: @board, checks: @checks, sparklines: @sparklines %>
    </div>

    <aside class="tb-stack-14">
      <div class="tb-card tb-card-pad">
        <div class="tb-eyebrow" style="margin-bottom: 10px;">This board</div>
        <% counts = @board.counts %>
        <div class="tb-stack-6">
          <div class="tb-receipt-row is-good"><span>up</span><span data-down-target="upCount"><%= counts[:up] %></span></div>
          <div class="tb-receipt-row is-warn"><span>slow</span><span data-down-target="slowCount"><%= counts[:slow] %></span></div>
          <div class="tb-receipt-row" style="color: var(--tb-red);"><span>down</span><span data-down-target="downCount"><%= counts[:down] %></span></div>
          <div class="tb-receipt-row"><span>auto-refresh</span><span class="tb-mono">60s</span></div>
        </div>
      </div>

      <div class="tb-card tb-card-pad">
        <div class="tb-eyebrow" style="margin-bottom: 10px;">Share</div>
        <div class="tb-actions-inline">
          <input class="tb-input tb-mono" readonly
                 value="<%= board_url(slug: @board.slug) %>"
                 data-down-target="shareInput"
                 style="font-size: 12px; height: 36px;">
          <button class="tb-btn tb-btn-ghost" style="height: 36px;"
                  data-action="click->down#copyShare">Copy</button>
        </div>
        <div class="tb-mono tb-muted" style="font-size: 11px; margin-top: 10px;">
          No account, no login. Anyone with the link can view this board.
        </div>
      </div>

      <div class="tb-card tb-card-pad">
        <div class="tb-eyebrow" style="margin-bottom: 6px;">Hosts</div>
        <ul class="tb-stack-6" style="list-style: none; padding: 0; margin: 0;">
          <% @board.hosts.each do |h| %>
            <li class="tb-mono" style="font-size: 12px; color: var(--tb-ink-2);"><%= h %></li>
          <% end %>
        </ul>
      </div>
    </aside>
  </div>
</section>
