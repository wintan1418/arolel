<section class="tb-admin-layout">
  <%= render "admin/sidebar", section: :overview %>

  <div class="tb-admin-content">
    <div class="tb-admin-pagehead">
      <div>
        <div class="tb-eyebrow">Admin workspace</div>
        <h1 class="tb-h1 tb-dashboard-title">Arolel control room</h1>
        <div class="tb-dashboard-user">Standard admin view for operations, users, and outbound email.</div>
      </div>
      <div class="tb-dashboard-actions">
        <%= link_to "User directory", admin_users_path, class: "tb-btn tb-btn-primary" %>
        <%= link_to "User dashboard", dashboard_path, class: "tb-btn tb-btn-ghost" %>
      </div>
    </div>

    <div class="tb-dashboard-stats tb-admin-stats">
      <div class="tb-stat">
        <span class="tb-stat-label">Visits today</span>
        <strong><%= number_with_delimiter(@totals[:visits_today]) %></strong>
        <span class="tb-stat-note">First-party page events</span>
      </div>
      <div class="tb-stat">
        <span class="tb-stat-label">Users</span>
        <strong><%= number_with_delimiter(@totals[:users]) %></strong>
        <span class="tb-stat-note"><%= number_with_delimiter(@totals[:super_admins]) %> admins</span>
      </div>
      <div class="tb-stat">
        <span class="tb-stat-label">Media queue</span>
        <strong><%= number_with_delimiter(@totals[:active_media_jobs]) %></strong>
        <span class="tb-stat-note"><%= number_with_delimiter(@totals[:failed_media_jobs_24h]) %> failed in 24h</span>
      </div>
      <div class="tb-stat">
        <span class="tb-stat-label">Conversions 7d</span>
        <strong><%= number_with_delimiter(@totals[:conversions_7d]) %></strong>
        <span class="tb-stat-note"><%= number_with_delimiter(@totals[:conversion_failures_7d]) %> failed</span>
      </div>
      <div class="tb-stat">
        <span class="tb-stat-label">Feedback 7d</span>
        <strong><%= number_with_delimiter(@totals[:feedback_7d]) %></strong>
        <span class="tb-stat-note"><%= number_with_delimiter(@totals[:paid_interest]) %> paid-feature signals</span>
      </div>
      <div class="tb-stat">
        <span class="tb-stat-label">Saved items</span>
        <strong><%= number_with_delimiter(@totals.values_at(:invoices, :boards, :url_sets, :signatures).sum) %></strong>
        <span class="tb-stat-note">Invoices, boards, sets, signatures</span>
      </div>
    </div>

    <div class="tb-admin-content-grid">
      <main class="tb-admin-maincol">
        <section class="tb-dash-section">
          <div class="tb-dash-section-head">
            <div>
              <h2>Traffic pulse</h2>
              <p>Last 7 days of server-side page events.</p>
            </div>
          </div>
          <div class="tb-card tb-card-pad tb-mini-chart">
            <% max_visits = [@visits_by_day.values.max.to_i, 1].max %>
            <% 6.downto(0).map { |n| n.days.ago.to_date }.each do |day| %>
              <% count = @visits_by_day[day] || 0 %>
              <div class="tb-chart-row">
                <span><%= day.strftime("%a") %></span>
                <div><i style="width: <%= ((count.to_f / max_visits) * 100).round %>%;"></i></div>
                <strong><%= number_with_delimiter(count) %></strong>
              </div>
            <% end %>
          </div>
        </section>

        <section class="tb-dash-section" id="queue-health">
          <div class="tb-dash-section-head">
            <div>
              <h2>Media queue health</h2>
              <p>Recent MP3, MP4, and compression jobs.</p>
            </div>
          </div>
          <div class="tb-card tb-card-pad">
            <div class="tb-dash-list tb-dash-list-plain">
              <% @recent_media_jobs.each do |job| %>
                <div class="tb-dash-row tb-admin-user-row">
                  <div class="tb-dash-maincell">
                    <div class="tb-dash-name"><%= job.operation_label %></div>
                    <div class="tb-dash-meta"><%= job.user&.email_address || "guest" %> · <%= number_to_human_size(job.input_bytes) %> in · <%= time_ago_in_words(job.created_at) %> ago</div>
                    <div class="tb-dash-meta"><%= job.progress_percent %>% · <%= job.status_message.presence || job.status.humanize %></div>
                  </div>
                  <span class="tb-pill <%= job.status == "succeeded" ? "tb-pill-ok" : (job.status == "failed" ? "tb-pill-down" : "tb-pill-warn") %>"><%= job.status %></span>
                </div>
              <% end %>
            </div>
          </div>
        </section>

        <section class="tb-dash-section">
          <div class="tb-dash-section-head">
            <div>
              <h2>User roster</h2>
              <p>Preview of newest and most recently active accounts.</p>
            </div>
            <%= link_to "Open directory", admin_users_path, class: "tb-btn tb-btn-ghost tb-btn-sm" %>
          </div>
          <div class="tb-card tb-table-wrap">
            <table class="tb-table">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Joined</th>
                  <th>Last seen</th>
                  <th>Events</th>
                  <th>Role</th>
                </tr>
              </thead>
              <tbody>
                <% @user_rows.each do |user| %>
                  <tr>
                    <td><%= user.email_address %></td>
                    <td class="tb-mono"><%= time_ago_in_words(user.created_at) %> ago</td>
                    <td class="tb-mono"><%= user.attributes["last_seen_at"].present? ? "#{time_ago_in_words(user.attributes["last_seen_at"])} ago" : "never" %></td>
                    <td class="tb-mono"><%= number_with_delimiter(user.attributes["activity_count"].to_i) %></td>
                    <td>
                      <% if user.super_admin? %>
                        <span class="tb-pill tb-pill-ok">admin</span>
                      <% else %>
                        <span class="tb-pill tb-pill-neu">user</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="tb-dash-section">
          <div class="tb-dash-section-head">
            <div>
              <h2>Recent activity</h2>
              <p>Server-side requests, excluding admin and assets.</p>
            </div>
          </div>
          <div class="tb-card tb-table-wrap">
            <table class="tb-table">
              <thead>
                <tr>
                  <th>When</th>
                  <th>Event</th>
                  <th>Path</th>
                  <th>User</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% @recent_events.each do |event| %>
                  <tr>
                    <td class="tb-mono"><%= time_ago_in_words(event.occurred_at) %> ago</td>
                    <td><%= event.event_name.humanize %></td>
                    <td class="tb-mono"><%= event.path %></td>
                    <td><%= event.user&.email_address || "guest" %></td>
                    <td class="tb-mono"><%= event.status %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </section>
      </main>

      <aside class="tb-admin-sidecol">
        <section class="tb-dash-section" id="mail-desk">
          <div class="tb-dash-section-head">
            <div>
              <h2>Send user update</h2>
              <p>Small-batch broadcast for account holders. Capped to keep the shared server light.</p>
            </div>
          </div>

          <%= form_with url: admin_user_messages_path, method: :post, class: "tb-card tb-card-pad tb-stack-14", local: true do |f| %>
            <div>
              <label class="tb-eyebrow" style="display: block; margin-bottom: 6px;">Audience</label>
              <%= f.select :audience,
                           [
                             ["All users (#{number_with_delimiter(@mail_audience_counts[:all_users])})", "all_users"],
                             ["Active in last 30 days (#{number_with_delimiter(@mail_audience_counts[:active_30d])})", "active_30d"],
                             ["Signed up in last 30 days (#{number_with_delimiter(@mail_audience_counts[:recent_signups_30d])})", "recent_signups_30d"],
                             ["Manual email list", "manual"]
                           ],
                           {},
                           class: "tb-input" %>
            </div>
            <div>
              <label class="tb-eyebrow" style="display: block; margin-bottom: 6px;">Manual emails</label>
              <%= f.text_area :emails, class: "tb-textarea", rows: 4, placeholder: "one@example.com\ntwo@example.com" %>
            </div>
            <div>
              <label class="tb-eyebrow" style="display: block; margin-bottom: 6px;">Subject</label>
              <%= f.text_field :subject, class: "tb-input", required: true, placeholder: "Arolel product update" %>
            </div>
            <div>
              <label class="tb-eyebrow" style="display: block; margin-bottom: 6px;">Message</label>
              <%= f.text_area :body, class: "tb-textarea", rows: 7, required: true, placeholder: "Write the update exactly as users should receive it." %>
            </div>
            <div class="tb-mono tb-muted" style="font-size: 11px; line-height: 1.55;">
              Sends from the Arolel mail domain with you as reply-to. Hard cap: <%= number_with_delimiter(Admin::UserMessagesController::MAX_RECIPIENTS) %> recipients per send.
            </div>
            <%= f.submit "Send user update", class: "tb-btn tb-btn-primary tb-btn-lg" %>
          <% end %>
        </section>

        <section class="tb-dash-section">
          <div class="tb-dash-section-head">
            <div>
              <h2>SMTP test</h2>
              <p>Send one direct SMTP check through Brevo.</p>
            </div>
          </div>
          <%= form_with url: admin_email_tests_path, method: :post, class: "tb-card tb-card-pad tb-stack-14", local: true do |f| %>
            <div>
              <label class="tb-eyebrow" style="display: block; margin-bottom: 6px;">To</label>
              <%= f.email_field :to, value: current_user.email_address, class: "tb-input", required: true %>
            </div>
            <div>
              <label class="tb-eyebrow" style="display: block; margin-bottom: 6px;">Subject</label>
              <%= f.text_field :subject, value: "Arolel email test", class: "tb-input", required: true %>
            </div>
            <div>
              <label class="tb-eyebrow" style="display: block; margin-bottom: 6px;">Message</label>
              <%= f.text_area :body, value: "This confirms Arolel can send email through Brevo SMTP.", class: "tb-textarea", rows: 5, required: true %>
            </div>
            <%= f.submit "Send SMTP test", class: "tb-btn tb-btn-ghost tb-btn-lg" %>
          <% end %>
        </section>

        <section class="tb-dash-section">
          <div class="tb-dash-section-head">
            <div>
              <h2>Top tools</h2>
              <p>Grouped from paths over the last 30 days.</p>
            </div>
          </div>
          <div class="tb-card tb-card-pad">
            <div class="tb-dash-list tb-dash-list-plain">
              <% @top_tools.each do |tool, count| %>
                <div class="tb-dash-row tb-admin-path-row">
                  <div class="tb-dash-maincell">
                    <div class="tb-dash-name"><%= tool.presence || "home" %></div>
                  </div>
                  <span class="tb-dash-money"><%= number_with_delimiter(count) %> visits</span>
                </div>
              <% end %>
            </div>
          </div>
        </section>

        <section class="tb-dash-section">
          <div class="tb-dash-section-head">
            <div>
              <h2>Conversion health</h2>
              <p>Server-side conversion success and failure counts.</p>
            </div>
          </div>
          <div class="tb-card tb-card-pad">
            <div class="tb-dash-list tb-dash-list-plain">
              <% @conversion_stats.group_by { |(operation, _status), _count| operation }.each do |operation, rows| %>
                <% succeeded = rows.find { |(_, status), _| status == "succeeded" }&.last.to_i %>
                <% failed = rows.find { |(_, status), _| status == "failed" }&.last.to_i %>
                <div class="tb-dash-row tb-admin-path-row">
                  <div class="tb-dash-maincell">
                    <div class="tb-dash-name"><%= operation.tr("-", " ").upcase %></div>
                    <div class="tb-dash-meta"><%= number_with_delimiter(succeeded) %> succeeded · <%= number_with_delimiter(failed) %> failed</div>
                  </div>
                  <span class="tb-pill <%= failed.zero? ? "tb-pill-ok" : "tb-pill-warn" %>"><%= failed.zero? ? "healthy" : "watch" %></span>
                </div>
              <% end %>
            </div>
          </div>
        </section>

        <section class="tb-dash-section">
          <div class="tb-dash-section-head">
            <div>
              <h2>Roadmap feedback</h2>
              <p>Latest suggestions and contact messages.</p>
            </div>
            <%= link_to "Open inbox", admin_feedback_submissions_path, class: "tb-btn tb-btn-ghost tb-btn-sm" %>
          </div>
          <div class="tb-card tb-card-pad">
            <div class="tb-dash-list tb-dash-list-plain">
              <% @recent_feedback.each do |feedback| %>
                <div class="tb-dash-row tb-admin-user-row">
                  <div class="tb-dash-maincell">
                    <div class="tb-dash-name"><%= feedback.subject.presence || feedback.feature_area.presence || feedback.kind.humanize %></div>
                    <div class="tb-dash-meta"><%= feedback.sender_label %> · <%= time_ago_in_words(feedback.occurred_at) %> ago</div>
                    <div class="tb-dash-meta"><%= truncate(feedback.message, length: 120) %></div>
                  </div>
                  <span class="tb-pill <%= feedback.willing_to_pay? ? "tb-pill-ok" : "tb-pill-neu" %>"><%= feedback.willing_to_pay? ? "paid" : feedback.kind %></span>
                </div>
              <% end %>
            </div>
          </div>
        </section>
      </aside>
    </div>
  </div>
</section>
