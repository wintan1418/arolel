<section class="tb-hero">
  <div>
    <div class="tb-eyebrow">Nine everyday tools · one honest app</div>
    <h1 class="tb-h1" style="margin-top: 18px;">
      The file tools you need,<br>
      <span style="color: var(--tb-red);">with</span> privacy up front.
    </h1>
    <p class="tb-text" style="margin-top: 22px; max-width: 52ch;">
      Arolel is a small suite of utilities built in Rails. Most file tools run entirely in your browser.
      Document conversions upload temporarily only when a server engine is required.
    </p>

    <div style="margin-top: 28px; display: flex; gap: 12px; flex-wrap: wrap;">
      <%= link_to "Convert a HEIC", heic_path, class: "tb-btn tb-btn-primary tb-btn-lg" %>
      <%= link_to "Merge a PDF",     pdf_path(op: "merge"), class: "tb-btn tb-btn-ghost tb-btn-lg" %>
      <%= link_to "Suggest a tool",  roadmap_path, class: "tb-btn tb-btn-ghost tb-btn-lg" %>
    </div>
  </div>

  <aside class="tb-receipt" aria-label="Session receipt">
    <div class="tb-receipt-title">
      <span class="tb-receipt-dot"></span>
      <span>This session · live</span>
    </div>
    <div class="tb-stack-6">
      <div class="tb-receipt-row is-good"><span>bytes sent to us</span><span data-receipt-target="bytes">0</span></div>
      <div class="tb-receipt-row is-good"><span>files uploaded</span><span>0</span></div>
      <div class="tb-receipt-row is-good"><span>trackers loaded</span><span>0</span></div>
      <div class="tb-receipt-row is-good"><span>cookies set</span><span>0</span></div>
      <div class="tb-receipt-row"><span>requests to our origin</span><span data-receipt-target="requests">0</span></div>
    </div>
    <div class="tb-receipt-foot">
      Open DevTools → Network. Confirm for yourself. This counter<br>
      reads <span class="tb-mono">performance.getEntriesByType('resource')</span>.
    </div>
  </aside>
</section>

<section style="margin-top: 24px;">
  <div class="tb-section-title">
    <h2 class="tb-h2" style="font-size: 22px;">The tools</h2>
    <span class="tb-eyebrow">01 · 02 · 03 · 04 · 05 · 06 · 07 · 08 · 09</span>
  </div>

  <div class="tb-tile-grid">
    <%= link_to heic_path, class: "tb-tile" do %>
      <span class="tb-tile-num">01</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="m21 15-5-5L5 21"/>
        </svg>
      </span>
      <div class="tb-tile-title">HEIC → JPG</div>
      <div class="tb-tile-desc">
        Convert iPhone HEIC photos to JPG, PNG or WebP. Bulk, unlimited,
        runs locally.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-badge-browser">runs in your browser</span>
        <span class="tb-mono">/heic-to-jpg</span>
      </div>
    <% end %>

    <%= link_to pdf_path(op: "merge"), class: "tb-tile" do %>
      <span class="tb-tile-num">02</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/>
          <path d="M14 2v6h6"/>
          <path d="M9 13h6M9 17h6"/>
        </svg>
      </span>
      <div class="tb-tile-title">PDF tools</div>
      <div class="tb-tile-desc">
        Merge, split, rotate, compress locally. Convert PDF, DOCX, CSV and
        page images when a server engine is needed.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-mono tb-muted">browser + temporary server tools</span>
        <span class="tb-mono">/pdf/merge</span>
      </div>
    <% end %>

    <%= link_to down_path, class: "tb-tile" do %>
      <span class="tb-tile-num">03</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9"/>
          <path d="M3 12h18"/>
          <path d="M12 3a14.5 14.5 0 0 1 0 18"/>
          <path d="M12 3a14.5 14.5 0 0 0 0 18"/>
        </svg>
      </span>
      <div class="tb-tile-title">Is It Down?</div>
      <div class="tb-tile-desc">
        Paste any URL, get a status. Save a list of hosts as a shareable
        board you can send your team.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-mono tb-muted">server-side · shareable</span>
        <span class="tb-mono">/down</span>
      </div>
    <% end %>

    <%= link_to open_urls_path, class: "tb-tile" do %>
      <span class="tb-tile-num">04</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
      </span>
      <div class="tb-tile-title">Bulk URL opener</div>
      <div class="tb-tile-desc">
        Paste a list of URLs, open them all in tabs, or save as a shareable
        set you can reuse every Monday.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-mono tb-muted">server-side · shareable</span>
        <span class="tb-mono">/open</span>
      </div>
    <% end %>

    <%= link_to image_path(op: "compress"), class: "tb-tile" do %>
      <span class="tb-tile-num">05</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M3 15l5-5 4 4 3-3 6 6"/>
          <circle cx="9" cy="9" r="1.5"/>
        </svg>
      </span>
      <div class="tb-tile-title">Image compress</div>
      <div class="tb-tile-desc">
        Shrink JPG, PNG and WebP images. Resize, re-encode, save the
        difference — all in your browser.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-badge-browser">runs in your browser</span>
        <span class="tb-mono">/images/compress</span>
      </div>
    <% end %>

    <%= link_to new_invoice_path, class: "tb-tile" do %>
      <span class="tb-tile-num">06</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/>
          <path d="M14 2v6h6"/>
          <path d="M9 13h6M9 17h4"/>
        </svg>
      </span>
      <div class="tb-tile-title">Invoice maker</div>
      <div class="tb-tile-desc">
        Three templates, line items, taxes. Download the PDF, or save to
        your dashboard if you sign up.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-badge-browser">runs in your browser</span>
        <span class="tb-mono">/invoice</span>
      </div>
    <% end %>

    <%= link_to sign_path, class: "tb-tile" do %>
      <span class="tb-tile-num">07</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 3 22l1.5-4.5L17 3Z"/>
          <path d="M15 5l4 4"/>
        </svg>
      </span>
      <div class="tb-tile-title">Sign PDF</div>
      <div class="tb-tile-desc">
        Draw or type a signature, drop it on the page, download the
        signed PDF. We never see the document.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-badge-browser">runs in your browser</span>
        <span class="tb-mono">/sign</span>
      </div>
    <% end %>

    <%= link_to media_path(op: "mp4-to-mp3"), class: "tb-tile" do %>
      <span class="tb-tile-num">08</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18V5l12-2v13"/>
          <circle cx="6" cy="18" r="3"/>
          <circle cx="18" cy="16" r="3"/>
        </svg>
      </span>
      <div class="tb-tile-title">MP4 → MP3</div>
      <div class="tb-tile-desc">
        Extract the audio from an MP4 video. Fast and local — perfect for
        podcasts, interviews, song rips.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-badge-browser">runs in your browser</span>
        <span class="tb-mono">/media/mp4-to-mp3</span>
      </div>
    <% end %>

    <%= link_to media_path(op: "webm-to-mp4"), class: "tb-tile" do %>
      <span class="tb-tile-num">09</span>
      <span class="tb-tile-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M23 7 16 12l7 5V7z"/>
          <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
        </svg>
      </span>
      <div class="tb-tile-title">WebM → MP4</div>
      <div class="tb-tile-desc">
        Convert a WebM recording to MP4 so it plays everywhere. Best for
        short clips — big files take a while.
      </div>
      <div class="tb-tile-meta">
        <span class="tb-badge-browser">runs in your browser</span>
        <span class="tb-mono">/media/webm-to-mp4</span>
      </div>
    <% end %>
  </div>
</section>

<section class="tb-seo">
  <h2>What is Arolel?</h2>
  <p>
    Arolel is an open-source suite of everyday web utilities: a HEIC-to-JPG photo converter,
    a PDF merger/splitter/rotater/compressor, a site uptime checker with shareable boards, and
    a bulk URL opener that saves sets of links you can reopen with one click.
  </p>
  <p>
    Most of these tools run entirely in your browser. Server-backed tools either need to be
    shareable, like uptime boards, or need system conversion software, like DOCX/PDF conversion.
    Everything is free, and accounts are optional.
  </p>
</section>
