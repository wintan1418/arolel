<%
  meta = {
    "mp4-to-mp3" => {
      title:   "MP4 → MP3",
      tool_no: "08",
      accept:  "video/mp4,video/quicktime,.mp4,.m4a,.mov,audio/mp4",
      drop:    "Choose an MP4 file to extract audio",
      cta:     "Upload and extract MP3",
      ext_in:  "mp4",
      ext_out: "mp3",
      note:    "Extract MP3 audio through a protected server queue so the browser runtime cannot get stuck.",
      seo_q:   "How do I extract MP3 audio from an MP4 video online?",
      seo_a:   "Upload an MP4, MOV or M4A file to Arolel's protected queue. FFmpeg extracts the first audio track and returns an MP3 download. Files are temporary and conversion is rate limited.",
      max_mb:  VideoCompression::MAX_BYTES / 1.megabyte
    },
    "webm-to-mp4" => {
      title:   "WebM → MP4",
      tool_no: "09",
      accept:  "video/webm,.webm",
      drop:    "Choose a WebM file to convert",
      cta:     "Upload and convert",
      ext_in:  "webm",
      ext_out: "mp4",
      note:    "Convert WebM to MP4 through a protected server queue with strict limits.",
      seo_q:   "How do I convert a WebM video to MP4 online?",
      seo_a:   "Upload a WebM file to Arolel's protected queue. FFmpeg transcodes it into an H.264 MP4 with server limits, low priority, and temporary output files.",
      max_mb:  VideoCompression::MAX_BYTES / 1.megabyte
    },
    "compress-video" => {
      title:   "Compress video",
      tool_no: "10",
      accept:  "video/mp4,video/quicktime,video/webm,.mp4,.m4v,.mov,.webm",
      drop:    "Choose a heavy video to compress",
      cta:     "Compress video",
      ext_in:  "video",
      ext_out: "mp4",
      note:    "Compress MP4, MOV and WebM through a protected server queue with strict limits.",
      seo_q:   "How do I compress a heavy video online?",
      seo_a:   "Upload one MP4, MOV or WebM file to Arolel's protected queue. FFmpeg compresses it as an H.264 MP4 with low server priority, one thread, a size limit, and temporary output files.",
      max_mb:  VideoCompression::MAX_BYTES / 1.megabyte
    }
  }.fetch(@op)
%>

<section class="tb-tool-layout">
  <div>
    <div style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <div class="tb-eyebrow">Tool <%= meta[:tool_no] %></div>
        <h1 class="tb-h1" style="font-size: 44px; margin-top: 14px;"><%= meta[:title] %></h1>
        <p class="tb-text" style="margin-top: 8px;"><%= meta[:note] %></p>
      </div>
      <div class="tb-tabs">
        <%= link_to "MP4 → MP3",  media_path(op: "mp4-to-mp3"),  class: ["tb-tab", ("is-active" if @op == "mp4-to-mp3")] %>
        <%= link_to "WebM → MP4", media_path(op: "webm-to-mp4"), class: ["tb-tab", ("is-active" if @op == "webm-to-mp4")] %>
        <%= link_to "Compress", media_path(op: "compress-video"), class: ["tb-tab", ("is-active" if @op == "compress-video")] %>
      </div>
    </div>

    <div class="tb-card tb-card-pad" style="margin-top: 26px;">
      <div class="tb-eyebrow">Protected queue</div>
      <h2 class="tb-h2" style="margin-top: 10px;">Server-side <%= meta[:title].downcase %></h2>
      <p class="tb-text" style="margin-top: 8px;">
        This avoids the browser FFmpeg runtime and gives you a real queued conversion.
      </p>
      <div class="tb-card tb-card-pad" style="margin-top: 14px; box-shadow: none;">
        <div class="tb-text-sm">
          Free for now while capacity is being tested. Downloads expire quickly and this feature may move to paid plans as usage grows.
        </div>
      </div>

      <% if signed_in? %>
        <%= form_with url: video_compressions_path, method: :post, multipart: true, local: true, class: "tb-stack-14", style: "margin-top: 18px;" do |form| %>
          <%= form.hidden_field :operation, value: @op %>
          <div>
            <label class="tb-label"><%= meta[:drop] %></label>
            <%= form.file_field :file,
                                accept: meta[:accept],
                                required: true,
                                class: "tb-input",
                                style: "padding-top: 8px;" %>
          </div>
          <div class="tb-mono tb-muted" style="font-size: 11px; line-height: 1.55;">
            Limit: <%= meta[:max_mb] %>MB. One active upload per user. Converted files are deleted after download and expire after <%= VideoCompression::OUTPUT_TTL / 1.hour %> hours if untouched.
          </div>
          <%= form.submit meta[:cta], class: "tb-btn tb-btn-primary tb-btn-lg" %>
        <% end %>
      <% else %>
        <div class="tb-card tb-card-pad" style="margin-top: 18px; box-shadow: none;">
          <div class="tb-text-sm">Log in or create an account to use server-side media conversion.</div>
          <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px;">
            <%= link_to "Log in", new_session_path, class: "tb-btn tb-btn-ghost" %>
            <%= link_to "Register", new_registration_path, class: "tb-btn tb-btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <aside>
    <div class="tb-card tb-card-pad" style="margin-top: 16px;">
      <div class="tb-eyebrow">How it runs</div>
      <div class="tb-stack-10" style="margin-top: 12px;">
        <div class="tb-receipt-row"><span>step 1</span><span>upload file</span></div>
        <div class="tb-receipt-row"><span>step 2</span><span>queue job</span></div>
        <div class="tb-receipt-row"><span>step 3</span><span>watch live progress</span></div>
        <div class="tb-receipt-row"><span>step 4</span><span>download result</span></div>
      </div>
    </div>

    <div class="tb-card tb-card-pad" style="margin-top: 16px;">
      <div class="tb-eyebrow">Server protection</div>
      <div class="tb-stack-10" style="margin-top: 12px;">
        <div class="tb-receipt-row"><span>upload cap</span><span><%= meta[:max_mb] %>MB</span></div>
        <div class="tb-receipt-row"><span>per user</span><span>1 active</span></div>
        <div class="tb-receipt-row"><span>global queue</span><span><%= VideoCompression::MAX_QUEUE %></span></div>
        <div class="tb-receipt-row"><span>ffmpeg threads</span><span><%= ENV.fetch("VIDEO_COMPRESSION_THREADS", "1") %></span></div>
        <div class="tb-receipt-row"><span>priority</span><span>low</span></div>
        <div class="tb-receipt-row"><span>retention</span><span><%= VideoCompression::OUTPUT_TTL / 1.hour %>h</span></div>
      </div>
    </div>
  </aside>
</section>

<section class="tb-seo">
  <h2><%= meta[:seo_q] %></h2>
  <p><%= meta[:seo_a] %></p>
</section>
