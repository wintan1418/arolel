<% total_saved = @invoices.size + @boards.size + @url_sets.size + @digital_signatures.size %>

<section class="tb-dashboard">
  <div class="tb-dashboard-head">
    <div>
      <div class="tb-eyebrow">Dashboard</div>
      <h1 class="tb-h1 tb-dashboard-title">Workspace</h1>
      <div class="tb-dashboard-user">Signed in as <span><%= current_user.email_address %></span></div>
    </div>
    <div class="tb-dashboard-actions">
      <%= link_to new_invoice_path, class: "tb-btn tb-btn-primary" do %>
        <span class="tb-btn-mark">+</span> Invoice
      <% end %>
      <%= link_to down_path, class: "tb-btn tb-btn-ghost" do %>
        <span class="tb-btn-mark">+</span> Board
      <% end %>
      <%= link_to sign_path, class: "tb-btn tb-btn-ghost" do %>
        <span class="tb-btn-mark">+</span> Signature
      <% end %>
      <%= button_to "Sign out", session_path, method: :delete, class: "tb-btn tb-btn-quiet", form: { style: "display:inline;" } %>
    </div>
  </div>

  <div class="tb-dashboard-stats">
    <div class="tb-stat">
      <span class="tb-stat-label">Saved items</span>
      <strong><%= total_saved %></strong>
      <span class="tb-stat-note">Across this account</span>
    </div>
    <div class="tb-stat">
      <span class="tb-stat-label">Invoices</span>
      <strong><%= @invoices.size %></strong>
      <span class="tb-stat-note">Drafts and saved PDFs</span>
    </div>
    <div class="tb-stat">
      <span class="tb-stat-label">Boards</span>
      <strong><%= @boards.size %></strong>
      <span class="tb-stat-note">Uptime watchlists</span>
    </div>
    <div class="tb-stat">
      <span class="tb-stat-label">Signatures</span>
      <strong><%= @digital_signatures.size %></strong>
      <span class="tb-stat-note">Reusable PNGs</span>
    </div>
  </div>

  <div class="tb-dashboard-grid">
    <main class="tb-dashboard-main">
      <section class="tb-dash-section">
        <div class="tb-dash-section-head">
          <div>
            <h2>Invoices</h2>
            <p>Saved billing documents.</p>
          </div>
          <%= link_to "New invoice", new_invoice_path, class: "tb-dash-link" %>
        </div>

        <% if @invoices.any? %>
          <div class="tb-dash-list">
            <% @invoices.each do |inv| %>
              <div class="tb-dash-row tb-dash-row-invoice">
                <div class="tb-dash-maincell">
                  <div class="tb-dash-name"><%= inv.number %></div>
                  <div class="tb-dash-meta"><%= inv.to_name.presence || "No client" %> · <%= time_ago_in_words(inv.created_at) %> ago</div>
                </div>
                <span class="tb-pill tb-pill-neu"><%= inv.template %></span>
                <span class="tb-dash-money"><%= inv.currency %> <%= number_with_delimiter((inv.total_cents || 0).to_f.round(2)) %></span>
                <div class="tb-dash-row-actions">
                  <%= link_to "Edit", edit_invoice_path(slug: inv.slug), class: "tb-btn tb-btn-ghost tb-btn-sm" %>
                  <%= button_to "Delete", invoice_path(slug: inv.slug),
                        method: :delete,
                        form: { data: { turbo_confirm: "Delete this invoice?" }, style: "display:inline;" },
                        class: "tb-btn tb-btn-quiet tb-btn-sm" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "empty", message: "No invoices yet.", action_label: "Create invoice", action_path: new_invoice_path %>
        <% end %>
      </section>

      <section class="tb-dash-section">
        <div class="tb-dash-section-head">
          <div>
            <h2>Uptime Boards</h2>
            <p>Shareable monitor boards.</p>
          </div>
          <%= link_to "New board", down_path, class: "tb-dash-link" %>
        </div>

        <% if @boards.any? %>
          <div class="tb-dash-list">
            <% @boards.each do |b| %>
              <div class="tb-dash-row tb-dash-row-board">
                <div class="tb-dash-maincell">
                  <div class="tb-dash-name"><%= b.name %></div>
                  <div class="tb-dash-meta"><%= b.hosts.size %> hosts · /down/b/<%= b.slug %></div>
                </div>
                <span class="tb-dash-age"><%= time_ago_in_words(b.created_at) %> ago</span>
                <%= link_to "Open", board_path(slug: b.slug), class: "tb-btn tb-btn-ghost tb-btn-sm" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "empty", message: "No uptime boards yet.", action_label: "Create board", action_path: down_path %>
        <% end %>
      </section>

      <section class="tb-dash-section">
        <div class="tb-dash-section-head">
          <div>
            <h2>URL Sets</h2>
            <p>Saved link collections.</p>
          </div>
          <%= link_to "New set", open_urls_path, class: "tb-dash-link" %>
        </div>

        <% if @url_sets.any? %>
          <div class="tb-dash-list">
            <% @url_sets.each do |s| %>
              <div class="tb-dash-row tb-dash-row-url">
                <div class="tb-dash-maincell">
                  <div class="tb-dash-name"><%= s.name %></div>
                  <div class="tb-dash-meta"><%= s.urls.size %> URLs · /o/<%= s.slug %></div>
                </div>
                <span class="tb-dash-age"><%= time_ago_in_words(s.created_at) %> ago</span>
                <%= link_to "Open", url_set_path(slug: s.slug), class: "tb-btn tb-btn-ghost tb-btn-sm" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "empty", message: "No saved URL sets yet.", action_label: "Create set", action_path: open_urls_path %>
        <% end %>
      </section>
    </main>

    <aside class="tb-dashboard-side">
      <section class="tb-dash-section">
        <div class="tb-dash-section-head">
          <div>
            <h2>Recent Conversions</h2>
            <p>Metadata only. No uploaded files are stored.</p>
          </div>
          <%= link_to "Convert", pdf_path(op: "docx-to-pdf"), class: "tb-dash-link" %>
        </div>

        <% if @tool_runs.any? %>
          <div class="tb-dash-list">
            <% @tool_runs.each do |run| %>
              <div class="tb-dash-row tb-dash-row-url">
                <div class="tb-dash-maincell">
                  <div class="tb-dash-name"><%= run.operation_label %></div>
                  <div class="tb-dash-meta">
                    <%= run.input_filename.presence || "file" %> · <%= time_ago_in_words(run.occurred_at) %> ago
                  </div>
                </div>
                <span class="tb-pill <%= run.status == "succeeded" ? "tb-pill-ok" : "tb-pill-warn" %>"><%= run.status %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "empty", message: "No conversions yet.", action_label: "Convert a document", action_path: pdf_path(op: "docx-to-pdf") %>
        <% end %>
      </section>

      <section class="tb-dash-section">
        <div class="tb-dash-section-head">
          <div>
            <h2>Digital Signatures</h2>
            <p>Reusable signature images.</p>
          </div>
          <%= link_to "Create", sign_path, class: "tb-dash-link" %>
        </div>

        <% if @digital_signatures.any? %>
          <div class="tb-signature-grid">
            <% @digital_signatures.each do |sig| %>
              <div class="tb-signature-card">
                <div class="tb-signature-preview">
                  <img src="<%= sig.image_data %>" alt="<%= sig.name %>">
                </div>
                <div class="tb-signature-card-foot">
                  <div>
                    <div class="tb-dash-name"><%= sig.name %></div>
                    <div class="tb-dash-meta"><%= time_ago_in_words(sig.created_at) %> ago</div>
                  </div>
                  <%= button_to "Delete", digital_signature_path(sig),
                        method: :delete,
                        form: { data: { turbo_confirm: "Delete this signature?" }, style: "display:inline;" },
                        class: "tb-btn tb-btn-quiet tb-btn-sm" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "empty", message: "No saved signatures yet.", action_label: "Create signature", action_path: sign_path %>
        <% end %>
      </section>

      <section class="tb-dash-note">
        <div class="tb-eyebrow" style="color: var(--tb-green);">Privacy</div>
        <p><strong>Files stay local where the tool allows it.</strong> Browser tools do not upload your PDFs, media, images, or documents. DOCX/PDF conversion uses temporary server uploads because it needs LibreOffice or Poppler. Saved signatures store only the reusable PNG you choose to keep.</p>
      </section>
    </aside>
  </div>
</section>
